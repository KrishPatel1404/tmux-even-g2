{
  "name": "tmux-g2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "sim": "bash scripts/sim.sh",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "pack": "npm run build && npx evenhub pack app.json dist -o tmux-g2.ehpk",
    "qr": "npx evenhub qr --url http://$(ipconfig getifaddr en0):5173",
    "test": "vitest",
    "kill": "bash scripts/kill.sh"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.13",
    "@evenrealities/evenhub-simulator": "^0.7.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.6"
  }
}
